{
  "name": "rill",
  "version": "0.1.0",
  "description": "A living online strategy table for three or four human and bot players.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rootsec1/katan.git"
  },
  "bugs": {
    "url": "https://github.com/rootsec1/katan/issues"
  },
  "homepage": "https://github.com/rootsec1/katan#readme",
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": "1.3.11"
  },
  "trustedDependencies": ["unrs-resolver"],
  "scripts": {
    "dev": "bun --bun next dev",
    "dev:realtime": "bunx --bun vercel dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "bunx eslint .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bunx playwright test",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun run src/server/db/migrate.ts",
    "simulate": "bun run scripts/simulate.ts",
    "cleanup": "bun run scripts/cleanup.ts"
  },
  "dependencies": {
    "@libsql/client": "0.17.4",
    "@vercel/functions": "3.7.5",
    "drizzle-orm": "0.45.2",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "ws": "8.21.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/bun": "1.3.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.8",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.11",
    "fast-check": "4.5.3",
    "typescript": "5.9.3"
  }
}
